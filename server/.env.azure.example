# Configure essas variáveis no Azure App Service
# Substitua os valores e execute o comando abaixo

# Opção 1: Via Azure CLI (recomendado)
# az webapp config appsettings set \
#   --resource-group production-saas \
#   --name portal-implantacao-backend \
#   --settings \
#     DATABASE_URL="sqlserver://saas-production-sql.database.windows.net:1433;database=portal_implantacao;user=saasAdmin;password=SEU_PASSWORD;encrypt=true;trustServerCertificate=false;connectionTimeout=30;" \
#     JWT_ACCESS_SECRET="seu-jwt-access-secret-com-minimo-10-caracteres" \
#     JWT_REFRESH_SECRET="seu-jwt-refresh-secret-com-minimo-10-caracteres" \
#     CORS_ORIGIN="https://portal-implantacao.azurewebsites.net" \
#     UPLOAD_DIR="./uploads" \
#     PORT="8080"

# Opção 2: Via Azure Portal
# 1. Acesse https://portal.azure.com
# 2. Vá para "portal-implantacao-backend" > "Configuration" > "Application settings"
# 3. Clique em "New application setting" e adicione cada variável abaixo:

# DATABASE_URL
# Valor: sqlserver://saas-production-sql.database.windows.net:1433;database=portal_implantacao;user=saasAdmin;password=SEU_PASSWORD;encrypt=true;trustServerCertificate=false;connectionTimeout=30;

# JWT_ACCESS_SECRET
# Valor: (mínimo 10 caracteres aleatórios)

# JWT_REFRESH_SECRET
# Valor: (mínimo 10 caracteres aleatórios)

# CORS_ORIGIN
# Valor: https://portal-implantacao.azurewebsites.net

# UPLOAD_DIR
# Valor: ./uploads

# PORT
# Valor: 8080

# 4. Clique em "OK" para cada setting
# 5. Clique em "Save" no topo da página
# 6. App Service reiniciará automaticamente
