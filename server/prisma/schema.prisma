generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("CLIENT")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  forms        OnboardingForm[]
  sessions     RefreshSession[]
  fileLogs     FileLog[]
  createdAppointments Appointment[] @relation("AppointmentCreatedBy")
  stageAcceptances StageAcceptance[] @relation("StageAcceptanceAcceptedBy")
  implementationLogs ImplementationLog[]
}

model RefreshSession {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OnboardingForm {
  id          String   @id @default(cuid())
  userId      String
  status      String   @default("RASCUNHO")
  currentStep Int      @default(0)
  stepData    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  pricing     PricingTable[]
  uploads     Upload[]
  history     SaveHistory[]
  users       OnboardingUser[]
  fileLogs    FileLog[]
  appointment Appointment?
  stageAcceptances StageAcceptance[]
  implementationLogs ImplementationLog[]

  @@index([userId])
  @@index([status])
}

model Appointment {
  id                       String   @id @default(cuid())
  formId                   String   @unique
  startAt                  DateTime
  endAt                    DateTime
  status                   String   @default("RESERVADO")
  createdByUserId          String
  externalCalendarProvider String?
  externalCalendarEventId  String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  form                      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  createdByUser             User           @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id])

  @@index([startAt, endAt])
  @@index([status, startAt])
  @@index([createdByUserId])
}

model StageAcceptance {
  id               String   @id @default(cuid())
  formId           String
  stageKey         String
  status           String   @default("CONCLUIDA")
  version          Int
  summarySnapshot  String
  acceptedByUserId String
  acceptedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  form             OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  acceptedByUser   User           @relation("StageAcceptanceAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: Cascade)

  @@index([formId, stageKey, acceptedAt])
  @@index([acceptedByUserId, acceptedAt])
}

model ImplementationLog {
  id         String   @id @default(cuid())
  formId     String
  userId     String?
  action     String
  entityType String
  entityId   String?
  metadata   String   @default("{}")
  createdAt  DateTime @default(now())

  form       OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  user       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([formId, createdAt])
  @@index([userId, createdAt])
  @@index([entityType, createdAt])
}

model OnboardingUser {
  id        String   @id @default(cuid())
  formId    String
  name      String
  email     String
  createdAt DateTime @default(now())

  form      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

model PricingTable {
  id        String   @id @default(cuid())
  formId    String
  sector    String
  regime    String
  rows      String   @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  form      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, sector, regime])
  @@index([regime])
  @@index([sector])
}

model Upload {
  id        String   @id @default(cuid())
  formId    String
  type      String
  filename  String
  path      String
  mimetype  String
  size      Int
  status    String   @default("NAO_ENVIADO")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  logs      FileLog[]

  @@unique([formId, type])
}

model FileLog {
  id        String   @id @default(cuid())
  formId    String
  uploadId  String?
  userId    String?
  type      String
  action    String
  status    String
  message   String?
  createdAt DateTime @default(now())

  form      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  upload    Upload?        @relation(fields: [uploadId], references: [id], onDelete: SetNull)
  user      User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([formId, createdAt])
  @@index([uploadId, createdAt])
  @@index([type, createdAt])
}

model SaveHistory {
  id        String   @id @default(cuid())
  formId    String
  stepIndex Int
  savedAt   DateTime @default(now())

  form      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, savedAt])
}

model PricingTemplate {
  id        String   @id @default(cuid())
  sector    String
  regime    String
  rows      String   @default("[]")
  createdAt DateTime @default(now())

  @@unique([sector, regime])
}
