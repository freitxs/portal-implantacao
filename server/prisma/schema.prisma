generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite no Prisma não suporta enum/Json.
// Armazenamos enums como STRING e objetos JSON como STRING.

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  passwordHash  String
  role          String   @default("CLIENT") // ADMIN | CLIENT
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  forms         OnboardingForm[]
  sessions      RefreshSession[]
}

model RefreshSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OnboardingForm {
  id          String   @id @default(cuid())
  userId      String
  status      String   @default("RASCUNHO") // RASCUNHO | ENVIADO
  currentStep Int      @default(0)
  stepData    String   @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  pricing     PricingTable[]
  uploads     Upload[]
  history     SaveHistory[]

  @@index([userId])
  @@index([status])
}

model PricingTable {
  id        String   @id @default(cuid())
  formId    String
  sector    String   // COMERCIO | SERVICOS | INDUSTRIA | MISTO | NAO_SEI
  regime    String   // SIMPLES | PRESUMIDO | REAL
  rows      String   @default("[]")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  form      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, sector, regime])
  @@index([regime])
  @@index([sector])
}

model Upload {
  id        String   @id @default(cuid())
  formId    String
  type      String   // CONTRATO | PROPOSTA
  filename  String
  path      String
  mimetype  String
  size      Int
  createdAt DateTime @default(now())

  form      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([formId, type])
}

model SaveHistory {
  id        String   @id @default(cuid())
  formId    String
  stepIndex Int
  savedAt   DateTime @default(now())

  form      OnboardingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, savedAt])
}

model PricingTemplate {
  id        String   @id @default(cuid())
  sector    String   // COMERCIO | SERVICOS | INDUSTRIA | MISTO | NAO_SEI
  regime    String   // SIMPLES | PRESUMIDO | REAL
  rows      String   @default("[]")
  createdAt DateTime @default(now())

  @@unique([sector, regime])
}
