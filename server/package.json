{
  "name": "onboarding-precificacao-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "build:azure": "tsc -p tsconfig.json",
    "start": "node scripts/azure-start.mjs",
    "start:prod": "pm2 start dist/index.js --no-daemon --name api",
    "prisma:prod": "prisma generate --schema prisma/schema.sqlserver.prisma && prisma migrate deploy --schema prisma/schema.sqlserver.prisma",
    "postinstall": "npm run prisma:prod",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "engines": {
    "node": ">=20 <25"
  },
  "dependencies": {
    "@prisma/adapter-mssql": "^7.4.2",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "pm2": "^5.4.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/mssql": "^9.1.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^25.3.3",
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "^5.5.4"
  }
}
